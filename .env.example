# Supabase project — required for cloud mode (storage_preference = 'cloud')
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Drive OAuth — required only for 'gdrive' storage mode.
# Create at https://console.cloud.google.com → OAuth 2.0 Client ID (Web application).
# Authorized origins must include http://localhost:5173 (dev) and your production URL.
# Drive API must be enabled for the Cloud project.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
